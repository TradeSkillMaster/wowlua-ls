{
  "name": "wowlua-ls",
  "displayName": "WoW Lua Language Server",
  "description": "Language server for WoW addon development - 9,000+ API stubs, 70 diagnostics, event typing, XML frame scanning, and more",
  "version": "0.0.1",
  "publisher": "TradeSkillMaster",
  "engines": {
    "vscode": "^1.75.0"
  },
  "icon": "icon.png",
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lua",
    "onLanguage:toc",
    "workspaceContains:**/*.toc",
    "workspaceContains:**/*.lua"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lua",
        "aliases": [
          "Lua",
          "lua"
        ],
        "extensions": [
          ".lua"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "wowlua-hover",
        "configuration": "./language-configuration.json"
      },
      {
        "id": "toc",
        "aliases": [
          "TOC",
          "WoW TOC"
        ],
        "extensions": [
          ".toc"
        ],
        "configuration": "./toc-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lua",
        "scopeName": "source.lua",
        "path": "./syntaxes/lua.tmLanguage.json"
      },
      {
        "language": "wowlua-hover",
        "scopeName": "source.wowlua-hover",
        "path": "./syntaxes/wowlua-hover.tmLanguage.json"
      },
      {
        "language": "toc",
        "scopeName": "source.toc",
        "path": "./syntaxes/toc.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "lua",
        "scopes": {
          "builtinConstant": [
            "constant.language.lua",
            "constant.language"
          ]
        }
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".wowluarc.json",
        "url": "./wowluarc.schema.json"
      }
    ],
    "configurationDefaults": {
      "[lua]": {
        "editor.formatOnType": true,
        "editor.stickyScroll.defaultModel": "foldingProviderModel",
        "editor.wordBasedSuggestions": "off"
      }
    }
  },
  "scripts": {
    "build": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "test:grammar": "vscode-tmgrammar-test -g syntaxes/lua.tmLanguage.json syntaxes/tests/lua.test.lua",
    "test:grammar:snap": "vscode-tmgrammar-snap -g syntaxes/wowlua-hover.tmLanguage.json -s source.wowlua-hover syntaxes/tests/hover.test.wowlua-hover",
    "test": "npm run test:grammar && npm run test:grammar:snap",
    "package": "npm run build && vsce package"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TradeSkillMaster/wowlua-ls"
  },
  "homepage": "https://tradeskillmaster.github.io/wowlua-ls/",
  "bugs": {
    "url": "https://github.com/TradeSkillMaster/wowlua-ls/issues"
  },
  "keywords": [
    "lua",
    "wow",
    "warcraft",
    "language-server",
    "lsp",
    "addon"
  ],
  "author": "TradeSkillMaster",
  "license": "GPL-3.0",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
