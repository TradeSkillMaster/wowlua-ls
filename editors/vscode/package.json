{
  "name": "wowlua-ls",
  "displayName": "WoW Lua Language Server",
  "description": "Lua language server for World of Warcraft addons",
  "version": "0.0.1",
  "publisher": "Sapu94",
  "engines": {
    "vscode": "^1.75.0"
  },
  "icon": "icon.png",
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lua"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lua",
        "aliases": [
          "Lua",
          "lua"
        ],
        "extensions": [
          ".lua"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "wowlua-hover",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lua",
        "scopeName": "source.lua",
        "path": "./syntaxes/lua.tmLanguage.json"
      },
      {
        "language": "wowlua-hover",
        "scopeName": "source.wowlua-hover",
        "path": "./syntaxes/wowlua-hover.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "WoW Lua LS",
      "properties": {
        "wowluals.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the wowlua_ls binary. If empty, uses the binary from the workspace's cargo target directory."
        }
      }
    }
  },
  "scripts": {
    "test:grammar": "vscode-tmgrammar-test -g syntaxes/lua.tmLanguage.json syntaxes/tests/lua.test.lua",
    "test:grammar:snap": "vscode-tmgrammar-snap -g syntaxes/wowlua-hover.tmLanguage.json -s source.wowlua-hover syntaxes/tests/hover.test.wowlua-hover",
    "test": "npm run test:grammar && npm run test:grammar:snap"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
