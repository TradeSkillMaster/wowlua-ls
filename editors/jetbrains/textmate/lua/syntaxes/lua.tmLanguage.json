    "field-type-desc": {
      "comment": "Type expression followed by optional description for @field annotations",
      "patterns": [
        {
          "comment": "fun() type: balanced parens, return type, then description",
          "begin": "\\s+(fun)\\s*(\\()",
          "beginCaptures": {
            "1": {"name": "keyword.control.lua"},
            "2": {"name": "keyword.operator.lua"}
          },
          "end": "(\\))([\\[\\]\\?\\!]*)(?:\\s*(:)\\s*((?:\\.\\.\\.|[a-zA-Z_])[a-zA-Z0-9_.|&\\[\\]?!<>\\-]*(?:\\s*,\\s*(?:\\.\\.\\.|[a-zA-Z_])[a-zA-Z0-9_.|&\\[\\]?!<>\\-]*)*))?(?:\\s+(.+))?|(?=[\\n#])",
          "endCaptures": {
            "1": {"name": "keyword.operator.lua"},
            "2": {"name": "keyword.operator.lua"},
            "3": {"name": "keyword.operator.lua"},
            "4": {"patterns": [{"include": "#emmydoc.type"}]},
            "5": {"name": "comment.block.documentation.lua"}
          },
          "patterns": [
            {"match": "([a-zA-Z_][a-zA-Z0-9_]*)(?=\\??\\s*:)", "name": "entity.name.variable.lua"},
            {"match": "[:\\?,]\\s*", "name": "keyword.operator.lua"},
            {"include": "#emmydoc.type"},
            {"include": "#string"}
          ]
        },
        {
          "comment": "Parameterized type (e.g. Map<K, V>) with description. Union members after > use a flat character class that doesn't handle spaces inside type params (e.g. |Map<K, V> stops at the space), but this is still better than the previous behavior of not capturing unions after > at all.",
          "begin": "\\s+([a-zA-Z_*][a-zA-Z0-9_.\\-]*)(\\<)",
          "beginCaptures": {
            "1": {"name": "support.type.lua"},
            "2": {"name": "keyword.operator.lua"}
          },
          "end": "(\\>)([\\[\\]\\?\\!]*)((?:\\s*[|&]\\s*(?:\\.\\.\\.|[a-zA-Z_*\"'`])[a-zA-Z0-9_.*<>,\\[\\]?!\"'`\\-]*)*)(?:\\s+(.+))?|(?=[\\n#])",
          "endCaptures": {
            "1": {"name": "keyword.operator.lua"},
            "2": {"name": "keyword.operator.lua"},
            "3": {"patterns": [{"include": "#emmydoc.type"}]},
            "4": {"name": "comment.block.documentation.lua"}
          },
          "patterns": [
            {"include": "#emmydoc.type"}
          ]
        },
        {
          "comment": "Type with parenthesized group (e.g. Type|(fun(): R, T)). Limited to one level of paren nesting; deeper nesting like (fun(x: (A|B)): R) may mis-split the description boundary.",
          "match": "\\s+((?:[a-zA-Z_*\"'`][a-zA-Z0-9_.*<>,|\\[\\]?!\"'`\\-]*)?\\([^()]*(?:\\([^()]*\\)[^()]*)*\\)[a-zA-Z0-9_.*<>,|\\[\\]?!\"'`\\-]*)(?:\\s+(.+))?",
          "captures": {
            "1": {"patterns": [{"include": "#emmydoc.type"}]},
            "2": {"name": "comment.block.documentation.lua"}
          }
        },
        {
          "comment": "{…} table literal type with description (one level of brace nesting)",
          "match": "\\s+(\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\})(?:\\s+(.+))?",
          "captures": {
            "1": {"patterns": [{"include": "#emmydoc.type"}]},
            "2": {"name": "comment.block.documentation.lua"}
          }
        },
        {
          "comment": "Simple/union type with optional description (allows spaces around | and &, and ...M variadic generic types). Delegates to emmydoc.type for rich sub-tokenization of operators and type names.",
          "match": "\\s+((?:\\.\\.\\.|[a-zA-Z_*\"'`])[a-zA-Z0-9_.*<>,\\[\\]?!\"'`\\-]*(?:\\s*[|&]\\s*(?:\\.\\.\\.|[a-zA-Z_*\"'`])[a-zA-Z0-9_.*<>,\\[\\]?!\"'`\\-]*)*)(?:\\s+(.+))?",
          "captures": {
            "1": {"patterns": [{"include": "#emmydoc.type"}]},
            "2": {"name": "comment.block.documentation.lua"}
          }
        }
      ]
    },

