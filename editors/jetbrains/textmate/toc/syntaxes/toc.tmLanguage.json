{
  "name": "WoW TOC",
  "scopeName": "source.toc",
  "patterns": [
    {
      "include": "#header"
    },
    {
      "include": "#comment"
    },
    {
      "include": "#directive-file"
    },
    {
      "include": "#file-path"
    }
  ],
  "repository": {
    "header": {
      "match": "^(##)\\s+([A-Za-z][A-Za-z0-9_-]*)\\s*(:)\\s*(.*?)\\s*$",
      "captures": {
        "1": {
          "name": "punctuation.definition.header.toc"
        },
        "2": {
          "name": "keyword.other.header-key.toc"
        },
        "3": {
          "name": "punctuation.separator.key-value.toc"
        },
        "4": {
          "name": "string.unquoted.header-value.toc"
        }
      }
    },
    "comment": {
      "match": "^#(?!#).*$",
      "name": "comment.line.number-sign.toc"
    },
    "directive-file": {
      "match": "^(\\[[^\\]]+\\])(.*)$",
      "captures": {
        "1": {
          "name": "entity.name.tag.directive.toc"
        },
        "2": {
          "name": "string.unquoted.file-path.toc"
        }
      }
    },
    "file-path": {
      "match": "^(?!##)(?!#)[^\\[\\s].*$",
      "name": "string.unquoted.file-path.toc"
    }
  }
}
