<idea-plugin>
    <id>com.tradeskillmaster.wowlua-ls</id>
    <name>WoW Lua Language Server</name>
    <vendor email="sapu@tradeskillmaster.com"
            url="https://github.com/TradeSkillMaster/wowlua-ls">TradeSkillMaster</vendor>

    <description><![CDATA[
    Lua language server for World of Warcraft addon development, powered by
    <a href="https://github.com/TradeSkillMaster/wowlua-ls">wowlua_ls</a>.

    <h3>Features</h3>
    <ul>
        <li>9,000+ WoW API stubs with hover documentation (retail, classic, classic_era)</li>
        <li>Code completion, go-to-definition, find references, rename</li>
        <li>55+ diagnostics for type safety, nil checking, and WoW-specific checks</li>
        <li>Generic types, metatable inference, builder patterns</li>
        <li>Flavor filtering &mdash; warns on APIs unavailable in your target game version</li>
        <li>Signature help with overload resolution</li>
        <li>Semantic token highlighting</li>
    </ul>

    <h3>Setup</h3>
    <p>Install the <code>wowlua_ls</code> binary and either add it to your PATH or configure
    the path in <b>Settings &rarr; Tools &rarr; WoW Lua LS</b>.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="Lua"
                implementationClass="com.tradeskillmaster.wowluals.WowLuaFileType"
                fieldName="INSTANCE"
                language="WowLua"
                extensions="lua"/>

        <lang.parserDefinition
                language="WowLua"
                implementationClass="com.tradeskillmaster.wowluals.WowLuaParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="WowLua"
                implementationClass="com.tradeskillmaster.wowluals.WowLuaSyntaxHighlighterFactory"/>

        <lang.commenter
                language="WowLua"
                implementationClass="com.tradeskillmaster.wowluals.WowLuaCommenter"/>

        <lang.braceMatcher
                language="WowLua"
                implementationClass="com.tradeskillmaster.wowluals.WowLuaBraceMatcher"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.tradeskillmaster.wowluals.WowLuaSettingsConfigurable"
                id="com.tradeskillmaster.wowluals.settings"
                displayName="WoW Lua LS"/>

        <applicationService
                serviceImplementation="com.tradeskillmaster.wowluals.WowLuaSettings"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="wowlua-ls"
                name="WoW Lua LS"
                factoryClass="com.tradeskillmaster.wowluals.WowLuaLanguageServerFactory">
            <description><![CDATA[
            Language server for World of Warcraft Lua addon development.
            ]]></description>
        </server>
        <languageMapping language="WowLua" serverId="wowlua-ls"/>
    </extensions>
</idea-plugin>
