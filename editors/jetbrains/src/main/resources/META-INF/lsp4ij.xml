<idea-plugin>
    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="wowlua-ls"
                name="WoW Lua LS"
                factoryClass="com.tradeskillmaster.wowluals.lsp4ij.WowLuaLanguageServerFactory">
            <description><![CDATA[
            Language server for World of Warcraft Lua addon development.
            ]]></description>
        </server>
        <!-- Pattern mappings (not fileType/language) so TextMate keeps
             providing the syntax coloration for .lua/.toc files. -->
        <fileNamePatternMapping patterns="*.lua" serverId="wowlua-ls" languageId="lua"/>
        <fileNamePatternMapping patterns="*.toc" serverId="wowlua-ls" languageId="toc"/>
    </extensions>
</idea-plugin>
