<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\Blizzard_SharedXML\UI.xsd">

    <!-- Mixin class definitions (virtual frames that act as mixins) -->
    <Frame name="MyBaseMixin" virtual="true">
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="DebugLabel" />
            </Layer>
        </Layers>
    </Frame>

    <!-- A frame that uses SearchMixin; SearchMixin methods should be able to
         access self.InputBox / self.SearchButton without undefined-field -->
    <Frame name="SearchFrame" virtual="true" mixin="SearchMixin">
        <Frames>
            <EditBox parentKey="InputBox" />
            <Button parentKey="SearchButton" />
        </Frames>
    </Frame>

    <!-- Virtual template: should create a class, no global -->
    <Frame name="MyBaseTemplate" virtual="true" mixin="MyBaseMixin">
        <KeyValues>
            <KeyValue key="label" value="default" type="string" />
            <KeyValue key="count" value="0" type="number" />
            <KeyValue key="enabled" value="true" type="boolean" />
        </KeyValues>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Background" />
            </Layer>
            <Layer level="ARTWORK">
                <FontString parentKey="Title" />
            </Layer>
        </Layers>
        <Frames>
            <Frame parentKey="ContentFrame" />
        </Frames>
    </Frame>

    <!-- Template inheriting another template -->
    <Button name="MyButtonTemplate" virtual="true" inherits="MyBaseTemplate" mixin="MyButtonMixin">
        <NormalTexture />
        <HighlightTexture parentKey="Glow" />
        <Animations>
            <AnimationGroup parentKey="FadeAnim" />
        </Animations>
    </Button>

    <!-- Non-virtual frame: should create both class and global -->
    <Button name="PlayerInfoFrame" parent="UIParent" inherits="MyButtonTemplate">
        <Size x="200" y="100" />
        <KeyValues>
            <KeyValue key="frameType" value="Player" type="string" />
        </KeyValues>
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="StatusText" />
            </Layer>
        </Layers>
        <!-- $parent resolution: $parentIcon -> PlayerInfoFrameIcon -->
        <Frames>
            <Frame name="$parentContainer" parentKey="Container" />
            <Frame name="$parentIcon" parentKey="Icon" />
        </Frames>
    </Button>

    <!-- Top-level texture template -->
    <Texture name="WoodTileTemplate" virtual="true" />

    <!-- Top-level animation group template -->
    <AnimationGroup name="FadeInTemplate" virtual="true">
        <Alpha parentKey="AlphaAnim" />
    </AnimationGroup>

    <!-- Intrinsic element definition -->
    <Button name="CustomButton" intrinsic="true" mixin="CustomButtonMixin" />

    <!-- Usage of intrinsic element -->
    <CustomButton name="SpecialButton" parent="UIParent" />

    <!-- Child element inheriting a template: parentKey field should get template type -->
    <Frame name="HostFrame" virtual="true">
        <Frames>
            <Frame parentKey="Panel" inherits="MyBaseTemplate" />
            <Button parentKey="ActionBtn" inherits="MyButtonTemplate" mixin="MyBaseMixin" />
            <Frame parentKey="Extra" mixin="MyBaseMixin" />
        </Frames>
    </Frame>

    <!-- parentArray with inherits -->
    <Frame name="ListFrame" virtual="true">
        <Frames>
            <Frame parentArray="Items" inherits="MyBaseTemplate" />
            <Frame parentArray="Items" />
        </Frames>
    </Frame>

    <!-- Script block should be skipped -->
    <Script>
        SOME_XML_GLOBAL = 42
    </Script>

    <!-- Nested parentKey propagation: unnamed child frames with parentKey should
         propagate their nested parentKey fields into the parent's field type.
         Without this, Sidebar.ActionBtn would be inaccessible because the
         unnamed inner frame (parentKey="Sidebar") has no name and its fields
         would be lost. -->
    <Frame name="DialogFrame" virtual="true" mixin="DialogFrameMixin">
        <Frames>
            <Frame parentKey="Sidebar" inherits="MyBaseTemplate">
                <Frames>
                    <Button parentKey="ActionBtn" />
                </Frames>
            </Frame>
        </Frames>
    </Frame>

    <!-- User @class override: Lua @class annotations should take precedence over
         XML-generated field types. The XML scanner infers MyPanel.Header as
         MyBaseTemplate, but the user defines @class MyPanel with @field Header
         typed as MyPanelHeader (a more specific class). -->
    <Frame name="MyPanel" virtual="true" mixin="MyPanelMixin">
        <Frames>
            <Frame parentKey="Header" inherits="MyBaseTemplate">
                <Frames>
                    <Button parentKey="CloseBtn" />
                </Frames>
            </Frame>
        </Frames>
    </Frame>

    <!-- Leaf region with inherits: base region type must be preserved.
         FontString inherits a Font object, not a FontString template. -->
    <Frame name="StyledFrame" virtual="true">
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Label" inherits="GameFontHighlight" />
                <Texture parentKey="Icon" inherits="IconTexCoordTemplate" />
            </Layer>
        </Layers>
    </Frame>

    <!-- Mixin self typed as Frame: a mixin referenced by mixin= on a Frame
         element should have its self typed as inheriting Frame, so Frame
         methods (SetSize, GetChildren, etc.) are accessible without false
         undefined-field or type-mismatch diagnostics. -->
    <Frame name="FrameMixVirtual" virtual="true" mixin="FrameMix" />

    <!-- Mixin self typed as Button: verifies the element's specific base type
         (Button, not just Frame) is used as the mixin's parent. -->
    <Button name="BtnMixVirtual" virtual="true" mixin="BtnMix" />

    <!-- Script handler function references: names bound via function= attribute
         on On* elements should be auto-allowed as globals -->
    <Frame name="HandlerTestFrame" virtual="true">
        <Scripts>
            <OnClick function="HandlerFrame_OnClick"/>
            <OnLoad function="HandlerFrame_OnLoad"/>
        </Scripts>
    </Frame>

    <!-- Names that should be filtered out (invalid Lua identifiers) -->
    <Frame name="!InvalidFrame" parent="UIParent" />
    <Texture name="Wood-Tile" virtual="true" />

</Ui>
